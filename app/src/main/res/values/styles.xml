<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Texto de etiquetas de formularios -->
    <style name="TextoLabel">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_marginTop">18dp</item>
        <item name="android:textColor">@color/texto_principal</item>
        <item name="android:textSize">13sp</item>
    </style>

    <!-- EditText de formularios -->
    <style name="InputFormulario">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">52dp</item>
        <item name="android:layout_marginTop">7dp</item>
        <item name="android:background">@drawable/bg_input</item>
        <item name="android:paddingStart">16dp</item>
        <item name="android:paddingEnd">16dp</item>
        <item name="android:textColor">@color/texto_principal</item>
        <item name="android:textColorHint">#8A97A8</item>
        <item name="android:textSize">14sp</item>
    </style>

    <!-- Botón principal verde -->
    <style name="BotonVerde">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">54dp</item>
        <item name="android:background">@drawable/bg_boton_verde</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:textColor">@color/blanco</item>
        <item name="android:textStyle">bold</item>
    </style>

    <!-- Botón con borde verde -->
    <style name="BotonBorde">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">54dp</item>
        <item name="android:background">@drawable/bg_boton_borde</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:textColor">@color/verde_oscuro</item>
        <item name="android:textStyle">bold</item>
    </style>

    <!-- Tarjeta simple -->
    <style name="CardSimple">
        <item name="android:background">@drawable/bg_card</item>
        <item name="android:padding">14dp</item>
    </style>

</resources>