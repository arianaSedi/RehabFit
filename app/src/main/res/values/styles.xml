<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="TituloPantalla">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:textColor">@color/texto_principal</item>
        <item name="android:textSize">24sp</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="SubtituloPantalla">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:textColor">@color/texto_secundario</item>
        <item name="android:textSize">13sp</item>
    </style>

    <style name="TextoChipVerde">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:background">@drawable/bg_chip_verde</item>
        <item name="android:paddingStart">8dp</item>
        <item name="android:paddingEnd">8dp</item>
        <item name="android:paddingTop">3dp</item>
        <item name="android:paddingBottom">3dp</item>
        <item name="android:textColor">@color/verde_oscuro</item>
        <item name="android:textSize">11sp</item>
    </style>

    <style name="TextoChipGris">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:background">@drawable/bg_chip_gris</item>
        <item name="android:paddingStart">8dp</item>
        <item name="android:paddingEnd">8dp</item>
        <item name="android:paddingTop">3dp</item>
        <item name="android:paddingBottom">3dp</item>
        <item name="android:textColor">@color/texto_principal</item>
        <item name="android:textSize">11sp</item>
    </style>

    <style name="CardAcceso">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">64dp</item>
        <item name="android:layout_columnWeight">1</item>
        <item name="android:background">@drawable/bg_card_blanca</item>
        <item name="android:gravity">center</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:textColor">@color/texto_principal</item>
        <item name="android:textSize">11sp</item>
    </style>


    <style name="CardMetrica">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">74dp</item>
        <item name="android:layout_columnWeight">1</item>
        <item name="android:gravity">center_vertical</item>
        <item name="android:padding">12dp</item>
    </style>

    <!-- Texto de etiquetas de formularios -->
    <style name="TextoLabel">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_marginTop">18dp</item>
        <item name="android:textColor">@color/texto_principal</item>
        <item name="android:textSize">13sp</item>
    </style>

    <!-- EditText de formularios -->
    <style name="InputFormulario">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">52dp</item>
        <item name="android:layout_marginTop">7dp</item>
        <item name="android:background">@drawable/bg_input</item>
        <item name="android:paddingStart">16dp</item>
        <item name="android:paddingEnd">16dp</item>
        <item name="android:textColor">@color/texto_principal</item>
        <item name="android:textColorHint">#8A97A8</item>
        <item name="android:textSize">14sp</item>
    </style>

    <style name="BotonVerde">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">54dp</item>
        <item name="android:background">@drawable/bg_boton_verde</item>
        <item name="android:backgroundTint">@color/verde_principal</item>
        <item name="backgroundTint">@color/verde_principal</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:textColor">@color/blanco</item>
        <item name="android:textStyle">bold</item>
        <item name="android:stateListAnimator">@null</item>
    </style>

    <style name="BotonBorde">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">54dp</item>
        <item name="android:background">@drawable/bg_boton_borde</item>
        <item name="android:backgroundTint">@color/blanco</item>
        <item name="backgroundTint">@color/blanco</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:textColor">@color/verde_oscuro</item>
        <item name="android:textStyle">bold</item>
        <item name="android:stateListAnimator">@null</item>
    </style>


    <style name="BotonDashboard">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">68dp</item>
        <item name="android:layout_columnWeight">1</item>
        <item name="android:background">@drawable/bg_card</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:textColor">@color/texto_principal</item>
        <item name="android:textSize">12sp</item>
    </style>

    <style name="ChipFiltro">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">38dp</item>
        <item name="android:layout_marginEnd">8dp</item>
        <item name="android:background">@drawable/bg_card</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:textColor">@color/texto_principal</item>
        <item name="android:textSize">12sp</item>
    </style>

    <style name="ChipFiltroVerde">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">32dp</item>
        <item name="android:layout_marginEnd">8dp</item>
        <item name="android:background">@drawable/bg_chip_verde</item>
        <item name="android:gravity">center</item>
        <item name="android:minWidth">68dp</item>
        <item name="android:paddingStart">14dp</item>
        <item name="android:paddingEnd">14dp</item>
        <item name="android:textColor">@color/verde_oscuro</item>
        <item name="android:textSize">12sp</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="ChipFiltroGris">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">32dp</item>
        <item name="android:layout_marginEnd">8dp</item>
        <item name="android:background">@drawable/bg_chip_gris</item>
        <item name="android:gravity">center</item>
        <item name="android:minWidth">68dp</item>
        <item name="android:paddingStart">14dp</item>
        <item name="android:paddingEnd">14dp</item>
        <item name="android:textColor">@color/texto_principal</item>
        <item name="android:textSize">12sp</item>
    </style>

    <style name="BottomNav">
        <item name="android:color">@android:color/transparent</item>
    </style>

</resources>