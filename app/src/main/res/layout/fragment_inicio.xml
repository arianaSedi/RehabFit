<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/fondo"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="18dp"
        android:paddingTop="18dp"
        android:paddingEnd="18dp"
        android:paddingBottom="12dp">

        <!-- Encabezado -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/txtSaludo"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Hola"
                    android:textColor="@color/texto_principal"
                    android:textSize="22sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/txtSubSaludo"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="¿Lista para tu sesión de hoy?"
                    android:textColor="@color/texto_secundario"
                    android:textSize="13sp" />
            </LinearLayout>

            <TextView
                android:id="@+id/txtAvatar"
                android:layout_width="46dp"
                android:layout_height="46dp"
                android:background="@drawable/bg_circulo_verde"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center"
                android:text="👤"
                android:textColor="@color/texto_principal"
                android:textSize="21sp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:background="@drawable/bg_alerta"
            android:paddingStart="14dp"
            android:paddingTop="12dp"
            android:paddingEnd="14dp"
            android:paddingBottom="12dp"
            android:orientation="horizontal">

            <ImageView
                android:layout_width="18dp"
                android:layout_height="18dp"
                android:src="@drawable/precaucion"
                android:layout_marginEnd="8dp"
                android:scaleType="fitCenter" />

            <TextView
                android:id="@+id/txtAvisoSeguridad"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Aviso de seguridad\nRealiza ejercicios suaves y detente si sientes dolor fuerte.\nLas recomendaciones no sustituyen atención médica."
                android:textColor="@color/alerta_texto"
                android:textSize="12sp" />

        </LinearLayout>

        <!-- Métricas -->
        <GridLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:columnCount="2"
            android:useDefaultMargins="true">

            <TextView
                android:id="@+id/txtSesionesSemana"
                style="@style/CardMetrica"
                android:background="@drawable/bg_card_verde"
                android:text="5\nSesiones esta semana"
                android:textColor="@color/texto_principal"
                android:textSize="13sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/txtTiempoTotal"
                style="@style/CardMetrica"
                android:background="@drawable/bg_card_verde"
                android:text="86 min\nTiempo total"
                android:textColor="@color/texto_principal"
                android:textSize="13sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/txtZonaTrabajada"
                style="@style/CardMetrica"
                android:background="@drawable/bg_card_azul"
                android:text="Rodilla\nZona trabajada"
                android:textColor="@color/azul_texto"
                android:textSize="15sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/txtDolorPromedio"
                style="@style/CardMetrica"
                android:background="@drawable/bg_card_naranja"
                android:text="3.2\nDolor promedio"
                android:textColor="@color/alerta_texto"
                android:textSize="15sp"
                android:textStyle="bold" />
        </GridLayout>

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btnIniciarRutina"
            style="@style/BotonVerde"
            android:layout_marginTop="16dp"
            android:text="Iniciar rutina de hoy"
            app:backgroundTint="@null" />

        <!-- Accesos rápidos -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:text="Accesos rápidos"
            android:textColor="@color/texto_principal"
            android:textSize="14sp" />

        <GridLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:columnCount="3"
            android:useDefaultMargins="true">

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btnIrEjercicios"
                style="@style/CardAcceso"
                android:text="Ejercicios"
                android:backgroundTint="@color/blanco" />

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btnIrRutina"
                style="@style/CardAcceso"
                android:text="Mi rutina"
                android:backgroundTint="@color/blanco" />

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btnIrHistorial"
                style="@style/CardAcceso"
                android:text="Historial"
                android:backgroundTint="@color/blanco" />

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btnIrProgreso"
                style="@style/CardAcceso"
                android:text="Progreso"
                android:backgroundTint="@color/blanco" />

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btnIrIA"
                style="@style/CardAcceso"
                android:text="Consultar IA"
                android:backgroundTint="@color/blanco" />

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btnIrComunidad"
                style="@style/CardAcceso"
                android:text="Comunidad"
                android:backgroundTint="@color/blanco" />
        </GridLayout>

    </LinearLayout>
</ScrollView>