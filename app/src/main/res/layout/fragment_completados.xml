<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/fondo"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="18dp">

        <ImageView
            android:layout_width="72dp"
            android:layout_height="72dp"
            android:layout_gravity="center_horizontal"
            android:src="@drawable/festejo"
            android:background="@drawable/bg_circulo_verde"
            android:scaleType="centerInside"
            android:padding="18dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:gravity="center"
            android:text="¡Sesión completada!"
            android:textColor="@color/texto_principal"
            android:textSize="25sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:text="¡Buen trabajo, sigue así!"
            android:textColor="@color/texto_secundario"
            android:textSize="13sp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="22dp"
            android:background="@drawable/bg_card_blanca"
            android:orientation="vertical"
            android:padding="18dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Resumen de sesión"
                android:textColor="@color/texto_principal"
                android:textSize="16sp"
                android:textStyle="bold" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <ImageView
                    android:layout_width="18dp"
                    android:layout_height="18dp"
                    android:src="@drawable/reloj"
                    android:layout_marginEnd="12dp" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Duración"
                    android:textColor="@color/texto_principal"
                    android:textSize="14sp" />

                <TextView
                    android:id="@+id/txtResumenDuracion"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="19 minutos"
                    android:textColor="@color/texto_principal"
                    android:textSize="14sp" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <ImageView
                    android:layout_width="18dp"
                    android:layout_height="18dp"
                    android:src="@drawable/listo"
                    android:layout_marginEnd="12dp" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Ejercicios completados"
                    android:textColor="@color/texto_principal"
                    android:textSize="14sp" />

                <TextView
                    android:id="@+id/txtResumenCompletados"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="3"
                    android:textColor="@color/texto_principal"
                    android:textSize="14sp" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <ImageView
                    android:layout_width="18dp"
                    android:layout_height="18dp"
                    android:src="@drawable/salto"
                    android:layout_marginEnd="12dp" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Ejercicios saltados"
                    android:textColor="@color/texto_principal"
                    android:textSize="14sp" />

                <TextView
                    android:id="@+id/txtResumenSaltados"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0"
                    android:textColor="@color/texto_principal"
                    android:textSize="14sp" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <ImageView
                    android:layout_width="18dp"
                    android:layout_height="18dp"
                    android:src="@drawable/humano"
                    android:layout_marginEnd="12dp" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Zona trabajada"
                    android:textColor="@color/texto_principal"
                    android:textSize="14sp" />

                <TextView
                    android:id="@+id/txtResumenZona"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Rodilla"
                    android:textColor="@color/texto_principal"
                    android:textSize="14sp" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <ImageView
                    android:layout_width="18dp"
                    android:layout_height="18dp"
                    android:src="@drawable/fecha"
                    android:layout_marginEnd="12dp" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Fecha"
                    android:textColor="@color/texto_principal"
                    android:textSize="14sp" />

                <TextView
                    android:id="@+id/txtResumenFecha"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="11 Jun 2026"
                    android:textColor="@color/texto_principal"
                    android:textSize="14sp" />
            </LinearLayout>

        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:background="@drawable/bg_boton_borde"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Registro de dolor"
                android:textColor="@color/verde_oscuro"
                android:textSize="15sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/txtDolorSesionCompletada"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:text="Antes de la sesión: 4/10\nDespués de la sesión: 2/10 · Mejora"
                android:textColor="@color/texto_secundario"
                android:textSize="13sp" />
        </LinearLayout>

        <TextView
            android:id="@+id/btnGuardarHistorial"
            android:layout_width="match_parent"
            android:layout_height="54dp"
            android:layout_marginTop="18dp"
            android:background="@drawable/bg_boton_verde"
            android:gravity="center"
            android:text="Guardar en historial"
            android:textColor="@color/blanco"
            android:textSize="15sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/btnVolverInicioSesion"
            android:layout_width="match_parent"
            android:layout_height="54dp"
            android:layout_marginTop="12dp"
            android:background="@drawable/bg_boton_borde"
            android:gravity="center"
            android:text="Volver al inicio"
            android:textColor="@color/verde_oscuro"
            android:textSize="15sp"
            android:textStyle="bold" />

    </LinearLayout>
</ScrollView>