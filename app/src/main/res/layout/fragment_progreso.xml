<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/fondo"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="18dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Progreso"
            android:textColor="@color/texto_principal"
            android:textSize="24sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Tu evolución semanal"
            android:textColor="@color/texto_secundario"
            android:textSize="13sp" />

        <GridLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:columnCount="2"
            android:useDefaultMargins="true">

            <TextView
                android:id="@+id/txtSesionesCompletadas"
                style="@style/CardMetrica"
                android:background="@drawable/bg_card_verde"
                android:text="0\nSesiones completas"
                android:textColor="@color/texto_principal"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/txtTiempoTerapia"
                style="@style/CardMetrica"
                android:background="@drawable/bg_card_verde"
                android:text="0 min\nTiempo de terapia"
                android:textColor="@color/verde_oscuro"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/txtZonaMasTrabajada"
                style="@style/CardMetrica"
                android:background="@drawable/bg_card_azul"
                android:text="Sin datos\nZona más trabajada"
                android:textColor="@color/azul_texto"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/txtDolorPromedioProgreso"
                style="@style/CardMetrica"
                android:background="@drawable/bg_card_naranja"
                android:text="0.0\nDolor promedio"
                android:textColor="@color/alerta_texto"
                android:textStyle="bold" />

        </GridLayout>

        <!-- GRAFICA SEMANAL -->

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:background="@drawable/bg_card_blanca"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Sesiones por día (esta semana)"
                android:textColor="@color/texto_principal"
                android:textSize="14sp"
                android:textStyle="bold" />

            <com.github.mikephil.charting.charts.BarChart
                android:id="@+id/barChartSemana"
                android:layout_width="match_parent"
                android:layout_height="220dp"
                android:layout_marginTop="12dp" />

        </LinearLayout>

        <!-- GRAFICA DOLOR -->

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:background="@drawable/bg_card_blanca"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Evolución del dolor (últimas 4 semanas)"
                android:textColor="@color/texto_principal"
                android:textSize="14sp"
                android:textStyle="bold" />

            <com.github.mikephil.charting.charts.BarChart
                android:id="@+id/barChartDolor"
                android:layout_width="match_parent"
                android:layout_height="220dp"
                android:layout_marginTop="12dp" />

        </LinearLayout>

        <TextView
            android:id="@+id/txtMensajeProgreso"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:background="@drawable/bg_card_verde"
            android:padding="16dp"
            android:text="Aún no hay suficientes datos para evaluar tu progreso."
            android:textColor="@color/verde_oscuro"
            android:textSize="13sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:gravity="center"
            android:text="El progreso puede variar según cada persona."
            android:textColor="@color/texto_secundario"
            android:textSize="12sp" />

    </LinearLayout>

</ScrollView>