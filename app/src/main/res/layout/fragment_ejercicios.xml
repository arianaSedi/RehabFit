<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/fondo"
    android:orientation="vertical"
    android:padding="16dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Ejercicios"
        android:textColor="@color/texto_principal"
        android:textSize="24sp"
        android:textStyle="bold" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Adaptados a tus necesidades"
        android:textColor="@color/texto_secundario"
        android:textSize="13sp" />

    <EditText
        android:id="@+id/edtBuscarEjercicio"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:layout_marginTop="14dp"
        android:background="@drawable/bg_input"
        android:hint="Buscar ejercicio..."
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:textColor="@color/texto_principal"
        android:textColorHint="@color/texto_secundario"
        android:textSize="14sp" />

    <HorizontalScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/btnTodos"
                style="@style/ChipFiltroVerde"
                android:text="Todos" />

            <TextView
                android:id="@+id/btnRodilla"
                style="@style/ChipFiltroGris"
                android:text="Rodilla" />

            <TextView
                android:id="@+id/btnTobillo"
                style="@style/ChipFiltroGris"
                android:text="Tobillo" />

            <TextView
                android:id="@+id/btnHombro"
                style="@style/ChipFiltroGris"
                android:text="Hombro" />

            <TextView
                android:id="@+id/btnEspalda"
                style="@style/ChipFiltroGris"
                android:text="Espalda" />

            <TextView
                android:id="@+id/btnSentado"
                style="@style/ChipFiltroGris"
                android:text="Sentado" />

        </LinearLayout>
    </HorizontalScrollView>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvEjercicios"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="14dp"
        android:layout_weight="1" />

</LinearLayout>