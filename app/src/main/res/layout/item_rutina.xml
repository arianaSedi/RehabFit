<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    android:background="@drawable/bg_card"
    android:orientation="horizontal"
    android:padding="14dp">

    <TextView
        android:id="@+id/txtNumeroRutina"
        android:layout_width="32dp"
        android:layout_height="32dp"
        android:background="@drawable/bg_circulo_verde"
        android:gravity="center"
        android:text="1"
        android:textColor="@color/blanco"
        android:textStyle="bold" />

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="12dp"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/txtNombreRutina"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Extensión suave de rodilla"
            android:textColor="@color/texto_principal"
            android:textSize="14sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/txtDetalleRutina"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Rodilla · 5 min · 10 rep · Baja"
            android:textColor="@color/texto_secundario"
            android:textSize="12sp" />
    </LinearLayout>

    <ImageView
        android:id="@+id/EliminarRutina"
        android:layout_width="32dp"
        android:layout_height="32dp"
        android:src="@drawable/basurero"
        android:background="?attr/selectableItemBackground"
        android:scaleType="centerInside" />

</LinearLayout>