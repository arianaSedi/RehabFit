<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/fondo"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="18dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Sesión en curso"
            android:textColor="@color/texto_principal"
            android:textSize="20sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/txtPlanSesion"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Plan: Recuperación adaptada"
            android:textColor="@color/texto_secundario"
            android:textSize="13sp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/txtProgresoEjercicio"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Ejercicio 1 de 3"
                android:textColor="@color/texto_principal"
                android:textSize="13sp" />

            <TextView
                android:id="@+id/txtPorcentajeSesion"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="33%"
                android:textColor="@color/verde_oscuro"
                android:textSize="13sp"
                android:textStyle="bold" />
        </LinearLayout>

        <ProgressBar
            android:id="@+id/progresoSesion"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="match_parent"
            android:layout_height="8dp"
            android:layout_marginTop="8dp"
            android:max="100"
            android:progress="0"
            android:progressTint="@color/verde_principal"
            android:progressBackgroundTint="@color/gris_chip" />

        <ImageView
            android:id="@+id/imgIconoSesion"
            android:layout_width="170dp"
            android:layout_height="170dp"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="24dp"
            android:background="@drawable/bg_card_verde"
            android:padding="24dp"
            android:scaleType="fitCenter"
            android:src="@drawable/pierna" />

        <TextView
            android:id="@+id/txtNombreEjercicioSesion"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="22dp"
            android:gravity="center"
            android:text="Extensión suave de rodilla"
            android:textColor="@color/texto_principal"
            android:textSize="18sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/txtDescripcionSesion"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:gravity="center"
            android:lineSpacingExtra="3dp"
            android:text="Siéntate recto. Extiende lentamente la pierna hasta que quede recta."
            android:textColor="@color/texto_secundario"
            android:textSize="13sp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="110dp"
            android:layout_marginTop="22dp"
            android:background="@drawable/bg_boton_borde"
            android:gravity="center"
            android:orientation="vertical">

            <TextView
                android:id="@+id/txtCronometroSesion"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="00:00"
                android:textColor="@color/verde_oscuro"
                android:textSize="40sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/txtEstadoCronometro"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Toca para pausar"
                android:textColor="@color/verde_oscuro"
                android:textSize="12sp" />
        </LinearLayout>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:background="@drawable/bg_alerta"
            android:padding="12dp"
            android:text="⚠ Detente si sientes dolor fuerte o mareo."
            android:textColor="@color/alerta_texto"
            android:textSize="12sp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="54dp"
            android:layout_marginTop="14dp"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/btnSaltarEjercicio"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_marginEnd="8dp"
                android:layout_weight="1"
                android:background="@drawable/bg_boton_borde"
                android:gravity="center"
                android:text="Saltar"
                android:textColor="@color/texto_secundario"
                android:textSize="14sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/btnCompletarEjercicio"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_marginStart="8dp"
                android:layout_weight="1"
                android:background="@drawable/bg_boton_verde"
                android:gravity="center"
                android:text="Completado"
                android:textColor="@color/blanco"
                android:textSize="14sp"
                android:textStyle="bold" />
        </LinearLayout>

        <TextView
            android:id="@+id/btnFinalizarSesion"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:gravity="center"
            android:text="Finalizar sesión"
            android:textColor="@color/alerta_texto"
            android:textSize="14sp"
            android:textStyle="bold" />

    </LinearLayout>
</ScrollView>