<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/fondo"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:id="@+id/btnVolverDetalle"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:background="@drawable/bg_boton_verde"
            android:gravity="center"
            android:text="←"
            android:textColor="@color/blanco"
            android:textSize="24sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/txtIconoDetalle"
            android:layout_width="match_parent"
            android:layout_height="145dp"
            android:layout_marginTop="12dp"
            android:background="@drawable/bg_card_verde"
            android:gravity="center"
            android:text="🏃"
            android:textSize="64sp" />

        <TextView
            android:id="@+id/txtNombreDetalle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:text="Nombre del ejercicio"
            android:textColor="@color/texto_principal"
            android:textSize="22sp"
            android:textStyle="bold" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/txtZonaDetalle"
                android:layout_width="0dp"
                android:layout_height="58dp"
                android:layout_weight="1"
                android:background="@drawable/bg_chip_gris"
                android:gravity="center"
                android:text="Zona"
                android:textColor="@color/texto_principal"
                android:textSize="12sp" />

            <TextView
                android:id="@+id/txtDificultadDetalle"
                android:layout_width="0dp"
                android:layout_height="58dp"
                android:layout_marginStart="8dp"
                android:layout_weight="1"
                android:background="@drawable/bg_chip_gris"
                android:gravity="center"
                android:text="Nivel"
                android:textColor="@color/texto_principal"
                android:textSize="12sp" />

            <TextView
                android:id="@+id/txtPosicionDetalle"
                android:layout_width="0dp"
                android:layout_height="58dp"
                android:layout_marginStart="8dp"
                android:layout_weight="1"
                android:background="@drawable/bg_chip_gris"
                android:gravity="center"
                android:text="Posición"
                android:textColor="@color/texto_principal"
                android:textSize="12sp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/txtDuracionDetalle"
                android:layout_width="0dp"
                android:layout_height="58dp"
                android:layout_weight="1"
                android:background="@drawable/bg_chip_gris"
                android:gravity="center"
                android:text="Duración"
                android:textColor="@color/texto_principal"
                android:textSize="12sp" />

            <TextView
                android:id="@+id/txtRepeticionesDetalle"
                android:layout_width="0dp"
                android:layout_height="58dp"
                android:layout_marginStart="8dp"
                android:layout_weight="1"
                android:background="@drawable/bg_chip_gris"
                android:gravity="center"
                android:text="Repeticiones"
                android:textColor="@color/texto_principal"
                android:textSize="12sp" />
        </LinearLayout>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:text="Descripción"
            android:textColor="@color/texto_principal"
            android:textSize="16sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/txtDescripcionDetalle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:background="@drawable/bg_card_verde"
            android:padding="12dp"
            android:text="Descripción del ejercicio"
            android:textColor="@color/verde_oscuro"
            android:textSize="14sp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:text="Instrucciones paso a paso"
            android:textColor="@color/texto_principal"
            android:textSize="16sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/txtInstruccionesDetalle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:lineSpacingExtra="5dp"
            android:text="Instrucciones"
            android:textColor="@color/texto_secundario"
            android:textSize="14sp" />

        <TextView
            android:id="@+id/txtPrecaucionDetalle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:background="@drawable/bg_card_naranja"
            android:padding="12dp"
            android:text="Advertencia"
            android:textColor="@color/alerta_texto"
            android:textSize="13sp" />

    </LinearLayout>
</ScrollView>