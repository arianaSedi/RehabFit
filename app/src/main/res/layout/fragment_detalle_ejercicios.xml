<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/fondo"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <ImageView
            android:id="@+id/imgIconoDetalle"
            android:layout_width="match_parent"
            android:layout_height="145dp"
            android:layout_marginTop="12dp"
            android:background="@drawable/bg_card_verde"
            android:padding="20dp"
            android:scaleType="fitCenter"
            android:src="@drawable/ic_ejercicios" />

        <TextView
            android:id="@+id/txtNombreDetalle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:text="Nombre del ejercicio"
            android:textColor="@color/texto_principal"
            android:textSize="22sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/txtInfoDetalle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:background="@drawable/bg_boton_borde"
            android:padding="12dp"
            android:text="✓ Bajo impacto · Movilidad suave · Recomendado para rodilla"
            android:textColor="@color/verde_oscuro"
            android:textSize="12sp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/txtZonaDetalle"
                android:layout_width="0dp"
                android:layout_height="58dp"
                android:layout_weight="1"
                android:background="@drawable/bg_chip_gris"
                android:gravity="center"
                android:text="Zona"
                android:textColor="@color/texto_principal"
                android:textSize="12sp" />

            <TextView
                android:id="@+id/txtDificultadDetalle"
                android:layout_width="0dp"
                android:layout_height="58dp"
                android:layout_marginStart="8dp"
                android:layout_weight="1"
                android:background="@drawable/bg_chip_gris"
                android:gravity="center"
                android:text="Nivel"
                android:textColor="@color/texto_principal"
                android:textSize="12sp" />

            <TextView
                android:id="@+id/txtPosicionDetalle"
                android:layout_width="0dp"
                android:layout_height="58dp"
                android:layout_marginStart="8dp"
                android:layout_weight="1"
                android:background="@drawable/bg_chip_gris"
                android:gravity="center"
                android:text="Posición"
                android:textColor="@color/texto_principal"
                android:textSize="12sp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/txtDuracionDetalle"
                android:layout_width="0dp"
                android:layout_height="58dp"
                android:layout_weight="1"
                android:background="@drawable/bg_chip_gris"
                android:gravity="center"
                android:text="Duración"
                android:textColor="@color/texto_principal"
                android:textSize="12sp" />

            <TextView
                android:id="@+id/txtRepeticionesDetalle"
                android:layout_width="0dp"
                android:layout_height="58dp"
                android:layout_marginStart="8dp"
                android:layout_weight="1"
                android:background="@drawable/bg_chip_gris"
                android:gravity="center"
                android:text="Repeticiones"
                android:textColor="@color/texto_principal"
                android:textSize="12sp" />
        </LinearLayout>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:text="Descripción"
            android:textColor="@color/texto_principal"
            android:textSize="16sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/txtDescripcionDetalle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:background="@drawable/bg_card_verde"
            android:lineSpacingExtra="4dp"
            android:padding="12dp"
            android:text="Descripción del ejercicio"
            android:textColor="@color/verde_oscuro"
            android:textSize="14sp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:text="Instrucciones paso a paso"
            android:textColor="@color/texto_principal"
            android:textSize="16sp"
            android:textStyle="bold" />

        <LinearLayout
            android:id="@+id/contenedorInstruccionesDetalle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:orientation="vertical" />

        <TextView
            android:id="@+id/txtPrecaucionDetalle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:background="@drawable/bg_card_naranja"
            android:lineSpacingExtra="4dp"
            android:padding="14dp"
            android:text="Precaución"
            android:textColor="@color/alerta_texto"
            android:textSize="13sp" />

        <TextView
            android:id="@+id/btnAgregarRutinaDetalle"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginTop="18dp"
            android:background="@drawable/bg_boton_verde"
            android:gravity="center"
            android:text="+  Agregar a rutina"
            android:textColor="@color/blanco"
            android:textSize="15sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/btnGuardarEjercicioDetalle"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginTop="12dp"
            android:background="@drawable/bg_boton_borde"
            android:gravity="center"
            android:text="☆  Guardar ejercicio"
            android:textColor="@color/verde_oscuro"
            android:textSize="14sp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:gravity="center"
            android:text="⚕ Datos desde API y guardado en Firebase"
            android:textColor="@color/texto_secundario"
            android:textSize="11sp" />

    </LinearLayout>
</ScrollView>