<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/layoutCardHistorialIA"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    android:background="@drawable/bg_card"
    android:clickable="true"
    android:focusable="true"
    android:orientation="vertical"
    android:padding="14dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <ImageView
            android:layout_width="42dp"
            android:layout_height="42dp"
            android:src="@drawable/med"
            android:background="@drawable/bg_info"
            android:scaleType="centerInside"
            android:padding="8dp" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/txtFechaHistorialIA"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="14 Jun 2026"
                android:textColor="@color/texto_secundario"
                android:textSize="12sp" />

            <TextView
                android:id="@+id/txtConsultaHistorialIA"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="3dp"
                android:text="Ejercicios suaves para rodilla"
                android:textColor="@color/texto_principal"
                android:textSize="14sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/txtZonaHistorialIA"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="7dp"
                android:background="@drawable/bg_chip_verde"
                android:paddingStart="10dp"
                android:paddingTop="4dp"
                android:paddingEnd="10dp"
                android:paddingBottom="4dp"
                android:text="Rodilla"
                android:textColor="@color/verde_oscuro"
                android:textSize="12sp" />

        </LinearLayout>

        <TextView
            android:layout_width="24dp"
            android:layout_height="match_parent"
            android:gravity="center"
            android:text="›"
            android:textColor="@color/verde_principal"
            android:textSize="28sp"
            android:textStyle="bold" />

    </LinearLayout>

    <androidx.appcompat.widget.AppCompatButton
        android:id="@+id/btnAgregarRutinaHistorialIA"
        android:layout_width="match_parent"
        android:layout_height="42dp"
        android:layout_marginTop="12dp"
        android:background="@drawable/bg_boton_verde"
        android:text="＋ Agregar ejercicios a rutina"
        android:textAllCaps="false"
        android:textColor="@color/blanco"
        android:textSize="13sp"
        android:textStyle="bold" />

</LinearLayout>