<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/fondo"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/txtIconoIA"
                android:layout_width="42dp"
                android:layout_height="42dp"
                android:background="@drawable/ic_medical"
                android:gravity="center"
                android:textColor="@color/blanco"
                android:textSize="22sp" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Consulta con IA"
                    android:textColor="@color/texto_principal"
                    android:textSize="20sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="3dp"
                    android:text="Recomendaciones generales de ejercicios"
                    android:textColor="@color/texto_secundario"
                    android:textSize="12sp" />

            </LinearLayout>

        </LinearLayout>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:background="@drawable/bg_alerta"
            android:lineSpacingExtra="2dp"
            android:padding="12dp"
            android:text="⚠  La IA no reemplaza a un médico o fisioterapeuta.\n    Consulta siempre con un profesional de salud."
            android:textColor="@color/alerta_texto"
            android:textSize="12sp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:background="@drawable/bg_card_azul"
            android:lineSpacingExtra="2dp"
            android:padding="12dp"
            android:text="¿Cómo estructurar tu consulta?\n   Tengo movilidad baja en la rodilla, dolor 4/10 y quiero ejercicios suaves sentado para recuperar movilidad."
            android:textColor="#4338CA"
            android:textSize="12sp"
            android:textStyle="italic" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:text="Tu consulta"
            android:textColor="@color/texto_principal"
            android:textSize="14sp"
            android:textStyle="bold" />

        <EditText
            android:id="@+id/edtConsultaIA"
            android:layout_width="match_parent"
            android:layout_height="108dp"
            android:layout_marginTop="8dp"
            android:background="@drawable/bg_info"
            android:gravity="top|start"
            android:hint="Describe tu zona afectada, nivel de movilidad, dolor actual y objetivo..."
            android:inputType="textMultiLine|textCapSentences"
            android:maxLines="5"
            android:minLines="4"
            android:padding="14dp"
            android:textColor="@color/texto_principal"
            android:textColorHint="#8A97A8"
            android:textSize="14sp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="22dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btnGenerarIA"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:background="@drawable/bg_chip_gris"
                android:enabled="false"
                android:text="Generar recomendación"
                android:textAllCaps="false"
                android:textColor="#98A2B3"
                android:textStyle="bold" />

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btnLimpiarIA"
                android:layout_width="50dp"
                android:layout_height="48dp"
                android:layout_marginStart="10dp"
                android:background="@drawable/bg_chip_gris"
                android:text="🗑"
                android:textAllCaps="false"
                android:textColor="@color/texto_principal" />

        </LinearLayout>

        <LinearLayout
            android:id="@+id/layoutResultadoIA"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:background="@drawable/bg_recomendacion"
            android:orientation="vertical"
            android:padding="14dp"
            android:visibility="gone">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="⚕  Recomendación generada"
                android:textColor="@color/verde_principal"
                android:textSize="14sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/txtRespuestaIA"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:lineSpacingExtra="3dp"
                android:textColor="@color/texto_principal"
                android:textSize="13sp" />

            <TextView
                android:id="@+id/txtEjerciciosIA"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:lineSpacingExtra="3dp"
                android:textColor="@color/texto_principal"
                android:textSize="13sp" />

        </LinearLayout>

        <TextView
            android:id="@+id/txtVerHistorialIA"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:gravity="center"
            android:text="Ver historial de consultas"
            android:textColor="#2815FF"
            android:textSize="14sp"
            android:textStyle="bold" />


    </LinearLayout>

</ScrollView>